      ],
      "prefixes": [
        { "p": "be-",    "hu": "betesz",   "en": "to put in, to insert",          "ex": [["Beteszi a kulcsot a zárba.","She puts the key in the lock."],["Betette a kocsit a garázsba.","He put the car in the garage."]] },
