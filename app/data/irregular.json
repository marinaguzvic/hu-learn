        {"tag":"past",      "hu":"Jót evett.",         "en":"He ate well."},
        {"tag":"imperative","hu":"Egyél valamit!",     "en":"Eat something!"},
        {"tag":"imperative","hu":"Egyen lassan.",      "en":"Eat slowly. (formal)"}
      ]
    },
