        { "p": "le-",    "hu": "letesz",   "en": "to put down, to set down",       "ex": [["Leteszi a táskát.","He puts down the bag."],["Letette a vizsgát.","She passed the exam."]] },
        { "p": "fel-",   "hu": "feltesz",  "en": "to put up; to pose (a question)","ex": [["Felteszi a kérdést.","She poses the question."],["Felteszi a kalapját.","He puts on his hat."]] },
        { "p": "hozzá-", "hu": "hozzátesz","en": "to add to, to contribute",       "ex": [["Hozzátesz valamit.","He adds something."],["Nincs mit hozzátennem.","I have nothing to add."]] }
      ],
      "examples": [
        {"tag":"present",   "hu":"Mit teszel?",         "en":"What are you doing / putting?"},
        {"tag":"present",   "hu":"Mindent megtesz értem.","en":"She does everything for me."},
        {"tag":"past",      "hu":"Mit tettél?",         "en":"What did you do?"},
        {"tag":"past",      "hu":"Jól tette.",          "en":"He did the right thing."},
        {"tag":"imperative","hu":"Tedd le!",            "en":"Put it down!"},
        {"tag":"imperative","hu":"Tegye be a táskába.", "en":"Put it in the bag. (formal)"}
