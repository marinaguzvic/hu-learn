        { "label": "Present", "rows": [["én","eszem"],["te","eszel"],["ő","eszik"],["mi","eszünk"],["ti","esztek"],["ők","esznek"]] },
        { "label": "Past",    "rows": [["én","ettem"],["te","ettél"],["ő","evett"],["mi","ettünk"],["ti","ettetek"],["ők","ettek"]] }
      ],
      "keyforms": [
        {"l":"infinitive","f":"enni"},{"l":"present 3sg","f":"eszik"},
        {"l":"past 3sg","f":"evett"},{"l":"imperative","f":"egyél! / egyen!"},{"l":"verbal noun","f":"evés"}
      ],
      "prefixes": [
        { "p": "meg-", "hu": "megeszik", "en": "to eat (something) up completely", "ex": [["Megeszi a vacsorát.","She eats up the dinner."],["Megette az egészet.","He ate the whole thing."]] }
      ],
      "examples": [
