{
  "verbs": [
    {
      "inf": "lenni",
      "base": "van / lesz / volt",
      "sub": "to be — the most irregular verb in Hungarian",
      "pattern": "Completely suppletive: present uses <b>van</b>, future uses <b>lesz</b>, past uses <b>volt</b>. In 3rd person present, the copula is dropped in predicative sentences ('tanár' = he is a teacher). Negation uses <b>nincs</b> (not 'nem van').",
      "forms": [
        { "label": "Present (van)", "rows": [["én","vagyok"],["te","vagy"],["ő","van"],["mi","vagyunk"],["ti","vagytok"],["ők","vannak"]] },
        { "label": "Future (lesz)", "rows": [["én","leszek"],["te","leszel"],["ő","lesz"],["mi","leszünk"],["ti","lesztek"],["ők","lesznek"]] },
        { "label": "Past (volt)",   "rows": [["én","voltam"],["te","voltál"],["ő","volt"],["mi","voltunk"],["ti","voltatok"],["ők","voltak"]] },
        { "label": "Conditional (lenne)", "rows": [["én","lennék"],["te","lennél"],["ő","lenne"],["mi","lennénk"],["ti","lennétek"],["ők","lennének"]] }
      ],
      "keyforms": [
        {"l":"infinitive","f":"lenni"},{"l":"present","f":"van"},{"l":"future","f":"lesz"},
        {"l":"past","f":"volt"},{"l":"negative present","f":"nincs / nincsen"},{"l":"imperative","f":"legyen!"}
      ],
      "prefixes": [
        { "p": "meg-", "hu": "megvan",  "en": "to have; to exist; to be done", "ex": [["Megvan a könyv?","Do you have the book?"],["Megvagyunk.","We're fine / We manage."]] },
        { "p": "el-",  "hu": "elvan",   "en": "to get along; to be away",      "ex": [["Elvan egyedül is.","She gets along on her own."],["Elvagyunk itt.","We're away here."]] }
      ],
      "examples": [
        {"tag":"present",    "hu":"Magyar vagyok.",        "en":"I am Hungarian."},
        {"tag":"present",    "hu":"Orvos.",                "en":"He is a doctor. (no 'van' in 3rd person predicates)"},
        {"tag":"negative",   "hu":"Nincs pénzem.",         "en":"I have no money. (nincs = there is no)"},
        {"tag":"negative",   "hu":"Nincs otthon.",         "en":"She's not at home."},
        {"tag":"future",     "hu":"Holnap orvos leszek.",  "en":"Tomorrow I will be a doctor."},
        {"tag":"past",       "hu":"Fáradt voltam.",        "en":"I was tired."},
        {"tag":"conditional","hu":"Jó lenne.",             "en":"It would be nice."},
        {"tag":"imperative", "hu":"Legyen türelmes!",      "en":"Be patient! (formal)"}
      ]
    },
    {
      "inf": "enni",
